/**
 * SPARKLUX ACADEMICS SECURITY RULES
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == "nalandaeeconnect@gmail.com"
      ) || request.auth.token.email == "hitakankshib@gmail.com"; // Adding developer for testing convenience if needed
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    match /users/{userId}/studentProfile/{profileId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if (isOwner(userId) && request.resource.data.id == userId) || isAdmin();
      allow update: if (isExistingOwner(userId) && request.resource.data.id == resource.data.id) || isAdmin();
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    match /users/{userId}/teacherProfile/{profileId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if (isOwner(userId) && request.resource.data.id == userId) || isAdmin();
      allow update: if (isExistingOwner(userId) && request.resource.data.id == resource.data.id) || isAdmin();
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /departmentInfo/{docId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /newsPosts/{newsPostId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /images/{imageId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /galleryItems/{galleryItemId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /semesters/{semesterId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /courseOfferings/{courseOfferingId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin() || (resource != null && isOwner(resource.data.teacherId));
    }

    match /enrollments/{enrollmentId} {
      allow get, list: if isSignedIn() && (isOwner(resource.data.studentId) || isOwner(resource.data.teacherId) || isAdmin());
      allow create: if isAdmin() || isOwner(request.resource.data.studentId);
      allow update: if isAdmin() || (resource != null && isOwner(resource.data.teacherId));
      allow delete: if isAdmin();
    }

    match /examinations/{examinationId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin() || (resource != null && isOwner(resource.data.teacherId));
    }

    match /grades/{gradeId} {
      allow get, list: if isSignedIn() && (isOwner(resource.data.studentId) || isOwner(resource.data.teacherId) || isAdmin());
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.teacherId == request.auth.uid);
      allow update: if (resource != null && isOwner(resource.data.teacherId)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /attendanceRecords/{attendanceRecordId} {
      allow get, list: if isSignedIn() && (isOwner(resource.data.studentId) || isOwner(resource.data.teacherId) || isAdmin());
      allow create, update: if isAdmin() || isOwner(request.resource.data.teacherId);
      allow delete: if isAdmin();
    }

    match /electricalEngineeringTopics/{topicId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /academicResources/{resourceId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
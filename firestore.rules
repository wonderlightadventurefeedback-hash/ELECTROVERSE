/**
 * SPARKLUX ACADEMICS SECURITY RULES
 *
 * Core Philosophy:
 * This ruleset implements a robust, relationship-based authorization model for an educational 
 * environment. It distinguishes between public departmental information, authenticated academic 
 * data, and private user-specific profiles.
 *
 * Data Structure:
 * - Public/General: /departmentInfo, /newsPosts, /images, /galleryItems, /electricalEngineeringTopics, /academicResources.
 * - Authenticated Browsing: /semesters, /courses, /courseOfferings.
 * - Private User Scopes: /users/{userId}/studentProfile, /users/{userId}/teacherProfile.
 * - Operational Records: /enrollments, /examinations, /grades, /attendanceRecords.
 * - Administrative Control: Managed via the /roles_admin/{adminId} collection.
 *
 * Key Security Decisions:
 * 1. Denormalization for Performance: Authorization IDs (studentId, teacherId) are stored 
 *    directly on operational documents (Grades, Enrollments) to avoid expensive cross-document 
 *    lookups during rule evaluation.
 * 2. Role-Based Access: Global administrators are identified by the existence of a document 
 *    in the 'roles_admin' collection.
 * 3. User Ownership: Students and Teachers have exclusive write access to their own profile 
 *    subcollections, while sharing read access to academic operational data based on their 
 *    enrolled/teaching status.
 * 4. Prototyping Flexibility: Rules strictly enforce 'who' can access data but remain 
 *    flexible regarding the 'shape' of the data to facilitate rapid development.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the provided ID matches the authenticated user's UID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the authenticated user is a registered administrator. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Helper for destructive operations to ensure document exists and user has rights. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Private profile information for students.
     * @path /users/{userId}/studentProfile/{profileId}
     * @allow Authenticated user (create) where UID matches path.
     * @deny User B (update) User A's profile.
     * @principle Path-based ownership and relational integrity.
     */
    match /users/{userId}/studentProfile/{profileId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    /**
     * @description Private profile information for teachers.
     * @path /users/{userId}/teacherProfile/{profileId}
     * @allow Authenticated user (create) where UID matches path.
     * @deny User B (update) User A's profile.
     * @principle Path-based ownership and relational integrity.
     */
    match /users/{userId}/teacherProfile/{profileId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    /**
     * @description Administrative roles registry.
     * @path /roles_admin/{adminId}
     * @allow Authenticated user (get) their own admin status.
     * @deny Public (create) admin records.
     * @principle Restricts role assignment to system-level operations.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; // Managed via console/backend only.
    }

    /**
     * @description Public departmental information (About Us, Contact).
     * @path /departmentInfo/{docId}
     * @allow Public (get) "general" document.
     * @deny Unauthenticated (update) department info.
     * @principle Public read with role-based write access.
     */
    match /departmentInfo/{docId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Public news and announcements.
     * @path /newsPosts/{newsPostId}
     * @allow Public (list) news posts.
     * @deny Non-admin (create) news post.
     * @principle Public consumption with administrative content control.
     */
    match /newsPosts/{newsPostId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Public image assets for galleries and carousels.
     * @path /images/{imageId}
     * @allow Public (get) image metadata.
     * @deny Unauthenticated (delete) images.
     */
    match /images/{imageId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description visual achievement gallery items.
     * @path /galleryItems/{galleryItemId}
     * @allow Public (list) gallery achievements.
     * @deny Non-admin (update) gallery metadata.
     */
    match /galleryItems/{galleryItemId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Academic semester definitions.
     * @path /semesters/{semesterId}
     * @allow Any student (list) semesters to see schedules.
     * @deny Non-admin (create) a new semester.
     */
    match /semesters/{semesterId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Master course catalog.
     * @path /courses/{courseId}
     * @allow Signed-in user (get) course details.
     * @deny Student (update) course description.
     */
    match /courses/{courseId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Specific instances of courses taught by teachers.
     * @path /courseOfferings/{courseOfferingId}
     * @allow Signed-in user (list) offerings.
     * @deny Student (update) teacherId for an offering.
     */
    match /courseOfferings/{courseOfferingId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin() || (resource != null && isOwner(resource.data.teacherId));
    }

    /**
     * @description Student enrollment records.
     * @path /enrollments/{enrollmentId}
     * @allow Student (get) their own enrollment.
     * @deny User A (list) User B's enrollments.
     * @principle Relationship-based access via denormalized IDs.
     */
    match /enrollments/{enrollmentId} {
      allow get, list: if isSignedIn() && (isOwner(resource.data.studentId) || isOwner(resource.data.teacherId) || isAdmin());
      allow create: if isAdmin() || isOwner(request.resource.data.studentId);
      allow update: if isAdmin() || (resource != null && isOwner(resource.data.teacherId));
      allow delete: if isAdmin();
    }

    /**
     * @description Examination events for course offerings.
     * @path /examinations/{examinationId}
     * @allow Enrolled student (get) exam details.
     * @deny Student (create) an examination record.
     */
    match /examinations/{examinationId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin() || (resource != null && isOwner(resource.data.teacherId));
    }

    /**
     * @description Student grades for specific examinations.
     * @path /grades/{gradeId}
     * @allow Student (get) their own grade.
     * @deny Student (create) their own grade.
     * @principle Secure access for students, write access for instructors.
     */
    match /grades/{gradeId} {
      allow get, list: if isSignedIn() && (isOwner(resource.data.studentId) || isOwner(resource.data.teacherId) || isAdmin());
      allow create: if isAdmin() || isOwner(request.resource.data.teacherId);
      allow update: if (resource != null && isOwner(resource.data.teacherId)) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Student attendance records.
     * @path /attendanceRecords/{attendanceRecordId}
     * @allow Student (list) their own attendance history.
     * @deny Student (update) an attendance status.
     */
    match /attendanceRecords/{attendanceRecordId} {
      allow get, list: if isSignedIn() && (isOwner(resource.data.studentId) || isOwner(resource.data.teacherId) || isAdmin());
      allow create, update: if isAdmin() || isOwner(request.resource.data.teacherId);
      allow delete: if isAdmin();
    }

    /**
     * @description AI Tutor knowledge base topics.
     * @path /electricalEngineeringTopics/{topicId}
     * @allow Public (list) engineering topics.
     * @deny Public (create) new topics.
     */
    match /electricalEngineeringTopics/{topicId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Academic resources linked to topics.
     * @path /academicResources/{resourceId}
     * @allow Public (get) study materials.
     * @deny Any user (delete) academic resources.
     */
    match /academicResources/{resourceId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}